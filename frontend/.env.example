# Ceylon Mango Frontend - Environment Template
# Copy this to .env.local or .env for local development

# API Configuration
# Backend API URL - Change based on environment
VITE_API_URL=http://localhost:8080/api

# Request timeout in milliseconds
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=false

# Resend Email Configuration (for reference)
VITE_RESEND_FROM_EMAIL=noreply@ceylonmango.lk

# Application Information
VITE_APP_NAME=Ceylon Mango
VITE_APP_VERSION=1.0.0

# Environment-Specific Overrides:
# For production: use .env.production
# For development: use .env.development or .env.local
# For staging: create .env.staging
